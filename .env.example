# Shopify Storefront API
# Store domain (no https://)
SHOPIFY_STORE_DOMAIN=fyfcz8-t6.myshopify.com

# Storefront API access token (from Shopify Admin → Apps → your app → API credentials)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# API version — update periodically; see https://shopify.dev/docs/api/storefront
SHOPIFY_API_VERSION=2026-01
